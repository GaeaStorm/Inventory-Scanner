{
  "name": "inventory-scanner",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 <25",
    "pnpm": ">=10 <12"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "warn"
    }
  },
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",

    "dev:server": "pnpm --filter @workspace/api-server run dev",
    "dev:app": "pnpm --filter @workspace/scanner-app run dev",
    "dev:mockup": "pnpm --filter @workspace/mockup-sandbox run dev"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}