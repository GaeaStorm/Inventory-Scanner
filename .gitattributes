# Normalize all text files in the repository.
* text=auto eol=lf

# Windows command files require CRLF most reliably.
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicit binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.xlsx binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary