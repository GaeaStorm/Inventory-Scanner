{
  "name": "@workspace/desktop-app",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-platform desktop application for Inventory Scanner",
  "author": "GaeaStorm",
  "license": "MIT",
  "main": "dist/main.cjs",
  "scripts": {
    "setup:workspace": "node ./scripts/setup-workspace.mjs",
    "dev": "node ./scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:electron": "node ./build.mjs",
    "build": "pnpm run build:renderer && pnpm run build:electron",
    "package": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "express": "^5.2.1",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "thread-stream": "3.1.0",
    "typescript": "~5.9.3",
    "vite": "catalog:"
  },
  "build": {
    "appId": "com.gaeastorm.inventoryscanner",
    "productName": "Inventory Scanner",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
