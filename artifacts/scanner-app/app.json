{
  "expo": {
    "name": "Stock Scanner",
    "slug": "scanner-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scanner-app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gaeastorm.inventoryscanner",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Stock Scanner connects to your inventory server on this Wi-Fi network.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.gaeastorm.inventoryscanner",
      "permissions": [
        "CAMERA",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Stock Scanner to use the camera to scan inventory QR codes."
        }
      ]
    ]
  }
}
