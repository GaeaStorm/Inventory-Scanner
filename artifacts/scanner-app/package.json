{
  "name": "@workspace/scanner-app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --lan",
    "dev:local": "expo start --localhost",
    "dev:tunnel": "expo start --tunnel",
    "build": "expo export --platform all --output-dir dist",
    "build:web": "expo export --platform web --output-dir dist",
    "serve:web": "expo serve",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "android:apk": "cd android && ./gradlew assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "54.0.23",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@workspace/api-client-react": "workspace:*",
    "expo": "~54.0.27",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "babel-preset-expo": "~54.0.11",
    "expo-camera": "^17.0.10",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
